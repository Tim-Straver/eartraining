<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient"
    android:padding="18dp">

    <LinearLayout
        android:id="@+id/homeContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_surface_card"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ear Training"
            android:textColor="@color/on_dark_muted"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/mode_label"
            android:textColor="@color/on_dark"
            android:textSize="30sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/modeChordProgressionButton"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="12dp"
            android:layout_weight="1"
            android:background="@drawable/bg_mode_progression"
            android:gravity="start|center_vertical"
            android:paddingStart="20dp"
            android:text="@string/mode_chord_progression"
            android:textAllCaps="false"
            android:textColor="#2A203C"
            android:textSize="24sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/modeIntervalButton"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginBottom="12dp"
            android:layout_weight="1"
            android:background="@drawable/bg_mode_interval"
            android:gravity="start|center_vertical"
            android:paddingStart="20dp"
            android:text="@string/mode_interval"
            android:textAllCaps="false"
            android:textColor="#352038"
            android:textSize="24sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/modeChordTypeButton"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/bg_mode_chord_type"
            android:gravity="start|center_vertical"
            android:paddingStart="20dp"
            android:text="@string/mode_chord_type"
            android:textAllCaps="false"
            android:textColor="#1B3438"
            android:textSize="24sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/trainingContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_surface_card"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/trainingTopBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/backHomeButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/bg_answer_button"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="@string/back"
                android:textAllCaps="false"
                android:textColor="@color/on_dark"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/modeTitleLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:textColor="@color/on_dark"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/questionLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:textColor="@color/on_dark"
            android:textSize="20sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/playAudioButton"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_play_button"
            android:text="@string/play_audio"
            android:textColor="@color/on_accent"
            android:textSize="40sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/streakFireLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/streak_fire"
                android:textColor="@color/on_dark"
                android:textSize="28sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/streakLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/streak_label_default"
                android:textColor="@color/on_dark"
                android:textSize="22sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="10dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/answerGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>

        <Button
            android:id="@+id/nextQuestionButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_primary_button"
            android:text="@string/next_question"
            android:textAllCaps="false"
            android:textColor="@color/on_accent"
            android:textSize="20sp"
            android:textStyle="bold" />
    </LinearLayout>
</FrameLayout>
